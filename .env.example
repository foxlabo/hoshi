# Hoshi environment.
# Copy to .env.local and adjust as needed.

# Local SQLite database (relative paths resolved from project root).
DATABASE_URL=file:./hoshi.db

# Absolute or project-relative path to the directory of photos to index.
# Hoshi NEVER modifies the originals — it only reads them and caches
# thumbnails under .hoshi-thumbs/.
HOSHI_LIBRARY_ROOT=./photos
